# Telegram bot token from BotFather.
TELEGRAM_TOKEN=123456789:replace-with-your-telegram-token

# Optional VirusTotal API key for IP reputation checks.
VT_API_KEY=replace-with-your-virustotal-api-key

# Optional AbuseIPDB API key for abuse confidence checks.
ABUSE_API_KEY=replace-with-your-abuseipdb-api-key

# Optional Have I Been Pwned API key for full email breach searches.
HIBP_API_KEY=replace-with-your-hibp-api-key

# Comma-separated Telegram user IDs allowed to use the bot.
ALLOWED_USERS=123456789,987654321

# Comma-separated Telegram chat IDs allowed to use the bot.
ALLOWED_CHATS=

# Comma-separated file prefixes that the FIM module is allowed to monitor.
FIM_ALLOWED_PREFIXES=/etc,/app

# Runtime file paths.
PID_FILE=/app/data/bot.pid
BOT_LOG_FILE=/app/logs/bot.log
LOG_FILE=/app/logs/threat_intel_log.md
FIM_FILE=/app/data/fim_hashes.json
REPORT_FILE=/app/data/cyber_volt_report.pdf

# Host/system integration paths.
AUTH_LOG_FILE=/var/log/auth.log
SURICATA_FAST_LOG_FILE=/var/log/suricata/fast.log
SSHD_CONFIG_FILE=/etc/ssh/sshd_config
NMAP_PATH=/usr/bin/nmap
ROOT_PATH=/

# Logging controls. LOG_FORMAT accepts "text" or "json".
LOG_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
